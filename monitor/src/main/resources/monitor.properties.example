#
# Global Settings - Copy this file to monitor.properties and fill in your own values
#
jdbc.url=jdbc:mysql://localhost:3306/bd_monitor
jdbc.username=your_db_username
jdbc.password=your_db_password

### Cluster Configuration
master_host_name=master
yarn_resource_manager=http://your_cluster_ip:8088/ws/v1/cluster
spark_history_api=http://your_cluster_ip:18080/api/v1
mesos_master_port=5050
mesos_agent_port=5051
hdfs_web=http://your_cluster_ip:9870
marathon_api=http://master:8888

## Unused (kept for reference)
yarn_node_manager=http://your_cluster_ip:8088/ws/v1/node
yarn_timeline_server=http://your_cluster_ip:8088/ws/v1/timeline
mapreduce_application_master=http://your_cluster_ip:8088/ws/v1/mapreduce
mapreduce_history_server=http://your_cluster_ip:8088/ws/v1/history
ganglia_api=http://your_cluster_ip:8080/ganglia/api/v2/metrics

#alert serverip and port
alert_server_ip=http://your_cluster_ip
alert_server_port=8887

#docker
docker_server_ip=your_docker_host_ip
docker_server_port=8655

#influxDB
influxDB_url=http://your_influxdb_ip:31002/
influxDB_username=root
influxDB_password=your_password
influxDB_dbname=agentDB

cassandra_table=cassandra
neo4j_table=neo4j

#tsfile / iotdb
tsfile.jdbc.url=jdbc:tsfile://localhost:6667/
tsfile.jdbc.username=root
tsfile.jdbc.password=your_password
