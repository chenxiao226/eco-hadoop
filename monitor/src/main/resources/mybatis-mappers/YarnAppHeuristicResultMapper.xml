<?xml version="1.0" encoding="UTF-8" ?> 
<!DOCTYPE mapper 
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.hit.monitor.dao.YarnAppHeuristicResultDao">
	<resultMap type="org.hit.monitor.model.YarnAppHeuristicResultDO"
		id="YarnAppHeuristicResultResult">
		<id property="id" column="id" />
		<result property="yarnAppResultId" column="yarn_app_result_id" />
		<result property="heuristicClass" column="heuristic_class" />
		<result property="heuristicName" column="heuristic_name" />
		<result property="severity" column="severity" />
		<result property="score" column="score" />
	</resultMap>

	<sql id="BaseSQL">
		y.id,y.yarn_app_result_id,y.heuristic_class,y.heuristic_name,y.severity,y.score
	</sql>

	<sql id="Condition">
		1=1
		<if test="id != null">
			AND y.id = #{id}
		</if>
		<if test="yarnAppResultId != null">
			AND y.yarn_app_result_id = #{yarnAppResultId}
		</if>
		<if test="heuristicClass != null">
			AND y.heuristic_class = #{heuristicClass}
		</if>
		<if test="heuristicName != null">
			AND y.heuristic_name = #{heuristicName}
		</if>
		<if test="severity != null">
			AND y.severity = #{severity}
		</if>
		<if test="score != null">
			AND y.score = #{score}
		</if>
	</sql>

	<sql id="ConditionExact">
		1=1
		<if test="id != null">
			AND y.id = #{id}
		</if>
		<if test="yarnAppResultId != null">
			AND y.yarn_app_result_id = #{yarnAppResultId}
		</if>
		<if test="heuristicClass != null">
			AND y.heuristic_class = #{heuristicClass}
		</if>
		<if test="heuristicName != null">
			AND y.heuristic_name = #{heuristicName}
		</if>
		<if test="severity != null">
			AND y.severity = #{severity}
		</if>
		<if test="score != null">
			AND y.score = #{score}
		</if>
	</sql>

	<!-- 根据主键查询是否存在 -->
	<select id="selectYarnAppHeuristicResultCountById"
		parameterType="java.lang.Long" resultType="java.lang.Integer">
		SELECT
		COUNT(1)
		FROM
		yarn_app_heuristic_result y
		WHERE
		y.id=#{id}
	</select>

	<!-- 根据主键查询 -->
	<select id="selectYarnAppHeuristicResultById" parameterType="java.lang.Long"
		resultMap="YarnAppHeuristicResultResult">
		SELECT
		<include refid="BaseSQL" />
		FROM
		yarn_app_heuristic_result y
		WHERE
		y.id=#{id}
	</select>

	<!-- 查询一个，必须传入能唯一确定一个的参数 -->
	<select id="selectOne" parameterType="org.hit.monitor.bo.QueryYarnAppHeuristicResultBO"
		resultMap="YarnAppHeuristicResultResult">
		SELECT
		<include refid="BaseSQL" />
		FROM
		yarn_app_heuristic_result y
		WHERE
		<include refid="ConditionExact" />
		LIMIT 1
	</select>

	<!-- 查询列表，一次最多查出1000条 -->
	<select id="selectYarnAppHeuristicResultList" parameterType="org.hit.monitor.bo.QueryYarnAppHeuristicResultBO"
		resultMap="YarnAppHeuristicResultResult">
		SELECT
		<include refid="BaseSQL" />
		FROM
		yarn_app_heuristic_result y
		WHERE
		<include refid="ConditionExact" />
		LIMIT 1000
	</select>

	<!-- 分页查找 -->
	<select id="selectYarnAppHeuristicResultPage" parameterType="org.hit.monitor.bo.QueryYarnAppHeuristicResultBO"
		resultMap="YarnAppHeuristicResultResult">
		SELECT
		<include refid="BaseSQL" />
		FROM
		yarn_app_heuristic_result y
		WHERE
		<include refid="Condition" />
		LIMIT #{pageIndex},#{pageSize}
	</select>

	<!-- 分页计数 -->
	<select id="selectYarnAppHeuristicResultCount" parameterType="org.hit.monitor.bo.QueryYarnAppHeuristicResultBO"
		resultType="java.lang.Integer">
		SELECT
		COUNT(1)
		FROM
		yarn_app_heuristic_result y
		WHERE
		<include refid="Condition" />
	</select>

	<!-- 添加 -->
	<insert id="insertYarnAppHeuristicResult" parameterType="org.hit.monitor.model.YarnAppHeuristicResultDO"
		useGeneratedKeys="true" keyProperty="id">
		INSERT INTO
		yarn_app_heuristic_result(
		yarn_app_result_id,
		heuristic_class,
		heuristic_name,
		severity,
		score
		) VALUES (
		#{yarnAppResultId},
		#{heuristicClass},
		#{heuristicName},
		#{severity},
		#{score}
		)
	</insert>

	<!-- 完全修改 -->
	<update id="updateYarnAppHeuristicResult" parameterType="org.hit.monitor.model.YarnAppHeuristicResultDO">
		UPDATE
		yarn_app_heuristic_result
		<set>
			yarn_app_result_id = #{yarnAppResultId},
			heuristic_class =
			#{heuristicClass},
			heuristic_name = #{heuristicName},
			severity =
			#{severity},
			score = #{score}
		</set>
		WHERE
		id=#{id}
	</update>

	<!-- 选择性修改 -->
	<update id="updateYarnAppHeuristicResultSelective"
		parameterType="org.hit.monitor.model.YarnAppHeuristicResultDO">
		UPDATE
		yarn_app_heuristic_result
		<set>
			<if test="yarnAppResultId != null">
				yarn_app_result_id = #{yarnAppResultId},
			</if>
			<if test="heuristicClass != null">
				heuristic_class = #{heuristicClass},
			</if>
			<if test="heuristicName != null">
				heuristic_name = #{heuristicName},
			</if>
			<if test="severity != null">
				severity = #{severity},
			</if>
			<if test="score != null">
				score = #{score}
			</if>
		</set>
		WHERE
		id=#{id}
	</update>

	<!-- 删除 -->
	<update id="deleteYarnAppHeuristicResult" parameterType="java.lang.Long">
		UPDATE
		yarn_app_heuristic_result
		SET
		is_delete = 1
		WHERE
		id=#{id}
	</update>

	<!-- 批量插入数据 -->
