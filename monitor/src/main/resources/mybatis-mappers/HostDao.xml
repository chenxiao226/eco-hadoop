<?xml version="1.0" encoding="UTF-8" ?> 
<!DOCTYPE mapper 
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.hit.monitor.dao.HostDao">
	<resultMap type="org.hit.monitor.model.HostDO" id="HostsResult">
		<id property="hostid" column="hostid" />
		<result property="proxyHostid" column="proxy_hostid" />
		<result property="host" column="host" />
		<result property="status" column="status" />
		<result property="available" column="available" />
		<result property="jmxAvailable" column="jmx_available" />
		<result property="name" column="name" />
		<result property="flags" column="flags" />
	</resultMap>
	
	<sql id="BaseSQL">
		h.hostid,h.proxy_hostid,h.host,h.status,h.available,h.jmx_available,h.name,h.flags
	</sql>
	
	<sql id="Condition">
		1=1
		<if test="hostid != null">
			AND h.hostid = #{hostid}
		</if>
		<if test="proxyHostid != null">
			AND h.proxy_hostid = #{proxyHostid}
		</if>
		<if test="host != null">
			AND h.host = #{host}
		</if>
		<if test="status != null">
			AND h.status = #{status}
		</if>
		<if test="available != null">
			AND h.available = #{available}
		</if>
		<if test="jmxAvailable != null">
			AND h.jmx_available = #{jmxAvailable}
		</if>
		<if test="name != null">
			AND h.name = #{name}
		</if>
		<if test="flags != null">
			AND h.flags = #{flags}
		</if>
	</sql>
	
	<sql id="ConditionExact">
		1=1
		<if test="hostid != null">
			AND h.hostid = #{hostid}
		</if>
		<if test="proxyHostid != null">
			AND h.proxy_hostid = #{proxyHostid}
		</if>
		<if test="host != null">
			AND h.host = #{host}
		</if>
		<if test="status != null">
			AND h.status = #{status}
		</if>
		<if test="available != null">
			AND h.available = #{available}
		</if>
		<if test="jmxAvailable != null">
			AND h.jmx_available = #{jmxAvailable}
		</if>
		<if test="name != null">
			AND h.name = #{name}
		</if>
		<if test="flags != null">
			AND h.flags = #{flags}
		</if>
	</sql>

	<!-- 根据主键查询是否存在 -->
	<select id="selectHostsCountById" parameterType="java.lang.Long" resultType="java.lang.Integer">
		SELECT
			 COUNT(1)
		FROM 
			hosts h
		WHERE 
			h.hostid=#{hostid}
	</select>
	
	<!-- 根据主键查询 -->
	<select id="selectHostsById" parameterType="java.lang.Long" resultMap="HostsResult">
		SELECT
			 <include refid="BaseSQL" />
		FROM 
			hosts h
		WHERE 
			h.hostid=#{hostid}
	</select>

	<!-- 查询一个，必须传入能唯一确定一个的参数 -->
	<select id="selectOne" parameterType="org.hit.monitor.bo.QueryHostsBO" resultMap="HostsResult">
		SELECT 
			<include refid="BaseSQL" />
		FROM 
			hosts h
		WHERE
			<include refid="ConditionExact" />
		LIMIT 1
	</select>
	
	<!-- 查询列表，一次最多查出1000条 -->
	<select id="selectHostsList" parameterType="org.hit.monitor.bo.QueryHostsBO" resultMap="HostsResult">
		SELECT 
			<include refid="BaseSQL" />
		FROM 
			hosts h
		WHERE
			<include refid="ConditionExact" />
		LIMIT 1000
	</select>
	
	<!-- 分页查找 -->
	<select id="selectHostsPage" parameterType="org.hit.monitor.bo.QueryHostsBO" resultMap="HostsResult">
		SELECT 
			<include refid="BaseSQL" />
		FROM 
			hosts h
		WHERE
			<include refid="Condition" />
		LIMIT #{pageIndex},#{pageSize}
	</select>
	
	<!-- 分页计数 -->
	<select id="selectHostsCount" parameterType="org.hit.monitor.bo.QueryHostsBO" resultType="java.lang.Integer">
		SELECT 
			COUNT(1)
		FROM 
			hosts h
		WHERE
			<include refid="Condition" />
	</select>

</mapper>