<?xml version="1.0" encoding="UTF-8" ?> 
<!DOCTYPE mapper 
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.hit.monitor.dao.AlertProcessDao">
	<resultMap type="org.hit.monitor.model.AlertProcessDO" id="AlertProcessResult">

		<result property="machine" column="machine" />
		<result property="process" column="process" />
		<result property="status" column="status"/>
	</resultMap>
	
	<sql id="BaseSQL">
	a.machine,a.process,a.status
	</sql>
	
	<sql id="Condition">
		1=1
		<if test="machine != null">
			AND a.machine = #{machine}
		</if>
		<if test="process != null">
			AND a.process = #{process}
		</if>
		<if test="status != null">
			AND a.status = #{status}
		</if>
	</sql>
	
	<sql id="ConditionExact">
		1=1

		<if test="machine != null">
			AND a.machine = #{machine}
		</if>
		<if test="process != null">
			AND a.process = #{process}
		</if>
		<if test="status != null">
			AND a.status = #{status}
		</if>
	</sql>

	<!-- 根据主键查询是否存在 -->
	<select id="selectAlertProcessCountById" parameterType="java.lang.Long" resultType="java.lang.Integer">
		SELECT
			 COUNT(1)
		FROM 
			alert_process a
		WHERE 
			a.id=#{id}
	</select>
	
	<!-- 根据主键查询 -->
	<select id="selectAlertProcessByMP" parameterType="java.lang.Long" resultMap="AlertProcessResult">
		SELECT
			 <include refid="BaseSQL" />
		FROM 
			alert_prcess a
		WHERE 
			a.machine=#{machine} and a.process=#{process}
	</select>

	<!-- 查询一个，必须传入能唯一确定一个的参数 -->
	<select id="selectOne" parameterType="org.hit.monitor.bo.QueryAlertProcessBO" resultMap="AlertProcessResult">
		SELECT 
			<include refid="BaseSQL" />
		FROM 
			alert_process a
		WHERE
			<include refid="ConditionExact" />
		LIMIT 1
	</select>
	
	<!-- 查询列表，一次最多查出1000条 -->
	<select id="selectAlertProcessList" parameterType="org.hit.monitor.bo.QueryAlertProcessBO" resultMap="AlertProcessResult">
		SELECT 
			<include refid="BaseSQL" />
		FROM 
			alert_process a
		WHERE
			<include refid="ConditionExact" />
		LIMIT 1000
	</select>
	
	<!-- 分页查找 -->
	<select id="selectAlertProcessPage" parameterType="org.hit.monitor.bo.QueryAlertProcessBO" resultMap="AlertProcessResult">
		SELECT 
			<include refid="BaseSQL" />
		FROM 
			alert_process a
		WHERE
			<include refid="Condition" />
		LIMIT #{pageIndex},#{pageSize}
	</select>
	
	<!-- 分页计数 -->
	<select id="selectAlertProcessCount" parameterType="org.hit.monitor.bo.QueryAlertProcessBO" resultType="java.lang.Integer">
		SELECT 
			COUNT(1)
		FROM 
			alert_process a
		WHERE
			<include refid="Condition" />
	</select>

	<!-- 添加 -->
	<insert id="insertAlertprocess" parameterType="org.hit.monitor.model.AlertProcessDO" useGeneratedKeys="true" keyProperty="id">
		INSERT INTO alert_process(
			machine,
			process,
			status,
		) VALUES (
			#{machine},
			#{process},
			#{status},
		)
	</insert>

	<!-- 完全修改 -->
	<update id="updateAlertProcess" parameterType="org.hit.monitor.model.AlertProcessDO">
		UPDATE 
			alert_process 
		<set>
			machine = #{machine},
			process = #{process},
			status = #{status},
		</set>
		WHERE 
			id=#{id}
	</update>
	
	<!-- 选择性修改 -->
	<update id="updateAlertProcessSelective" parameterType="org.hit.monitor.model.AlertProcessDO">
		UPDATE 
			alert_process 
		<set>
			<if test="machine != null">
				machine = #{machine},
			</if>
			<if test="process != null">
				process = #{process},
			</if>
			<if test="status != null">
				status = #{status},
			</if>
		</set>
		WHERE 
			id=#{id}
	</update>

</mapper>