<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" xmlns="http://logging.apache.org/log4j/2.0/config">
	<Appenders>
		<!-- 控制台输出 -->
		<Console name="ROOT" target="SYSTEM_OUT">
			<PatternLayout pattern="[%d{yyyy-MM-dd HH:mm:ss,SSS}]-[%p] %c - %m%n"/>
		</Console>

	</Appenders>

	<Loggers>
		<!-- 单独配置Spring日志 -->
		<Logger name="org.springframework" level="INFO" additivity="false">
			<AppenderRef ref="SPRING"/>
		</Logger>

		<!-- 根日志配置 -->
		<Root level="INFO">
			<AppenderRef ref="ROOT"/>
		</Root>
	</Loggers>
</Configuration>